function startSphere(sph) { curSphere=sph; curQ=0; go(renderQ,sph,0); }

/* ─── QUESTION ─── */
function renderQ(sph,qi) {
  const q=sph.questions[qi], tot=sph.questions.length, ak=`${sph.id}_${qi}`, prev=ST.answers[ak];
  const dots=Array.from({length:tot},(_,i)=>`<span class="${i<qi?'done':i===qi?'active':''}"></span>`).join('');
  const opts=q.opts.map(o=>`<button class="qopt${prev===o.s?' sel':''}" data-s="${o.s}"><span class="qopt__m"></span><span class="qopt__t">${o.t}</span></button>`).join('');

  document.getElementById('app').innerHTML=`
<div class="screen qscreen">
  <div class="qhdr">
    <div class="qtag"><span class="qtag__r">${sph.roman}</span><span class="qtag__n ls">${sph.name}</span></div>
    <div class="qdots">${dots}</div>
  </div>
  <div class="qcard">
    <h2 class="d qtext">${q.text}</h2>
    ${q.hint?`<p class="qhint">${q.hint}</p>`:''}
    <div class="qopts">${opts}</div>
    <div class="qnav">
      <button class="qback" id="backBtn" ${qi===0?'disabled':''}>Назад</button>
      <span class="qcount lx">${qi+1} / ${tot}</span>
    </div>
  </div>
</div>`;

  document.querySelectorAll('.qopt').forEach(b=>{
    b.onclick=()=>{
      ST.answers[ak]=+b.dataset.s; save(ST);
      document.querySelectorAll('.qopt').forEach(x=>x.classList.remove('sel'));
      b.classList.add('sel');
      setTimeout(()=>{ qi+1<tot ? go(renderQ,sph,qi+1) : finishSphere(sph); },320);
    };
  });
  document.getElementById('backBtn').onclick=()=>{ qi>0?go(renderQ,sph,qi-1):go(renderHub); };
}

/* ─── FINISH SPHERE ─── */
function finishSphere(sph) {
  let sum=0,cnt=0;
  sph.questions.forEach((_,i)=>{ const v=ST.answers[`${sph.id}_${i}`]; if(v!==undefined){sum+=v;cnt++;} });
  const sc=cnt>0?sum/cnt:0;
  ST.scores[sph.id]=sc;
  if(!ST.completed.includes(sph.id)){ST.completed.push(sph.id);ST.todayCount++;}
  save(ST);
  go(renderSphereDone,sph,sc,ST.completed.length===SPHERES.length);
}

