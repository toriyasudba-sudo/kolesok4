function getCardRecs(scores) {
  const s = Object.fromEntries(scores.map(x => [x.id, x.score]));
  const avg = scores.reduce((a,x) => a+x.score,0)/scores.length;
  const recs = [];

  if (s.health < 5 || s.rest < 5 || s.self < 5)
    recs.push({ ...CARDS.spa, why: 'Тело и отдых требуют внимания — эта карта возвращает тебя к себе через конкретные ритуалы.' });

  if (s.state < 5 || s.career < 5 || s.self < 5)
    recs.push({ ...CARDS.spiritual, why: 'Внутреннее состояние и смыслы — то, что сейчас нужно. Эта карта помогает остановиться и услышать себя.' });

  if (s.money < 5 || s.health < 5)
    recs.push({ ...CARDS.material, why: 'Здоровье, быт, качество жизни — конкретные действия, которые можно поставить в календарь.' });

  if (s.rel < 5 || s.env < 5)
    recs.push({ ...CARDS.offline, why: 'Живые встречи и среда важны — эта карта даёт повод выйти и быть среди людей своего круга.' });

  if (s.rel < 5 || s.env < 5)
    recs.push({ ...CARDS.online, why: 'Встречи с авторами и женщинами К4 помогут почувствовать себя менее одинокой.' });

  recs.push({ ...CARDS.bonus, why: 'Отобранные материалы и подарки месяца — можно взять только то, что откликается прямо сейчас.' });

  if (avg >= 6.5)
    recs.push({ ...CARDS.combo, why: 'У тебя есть ресурс для полного маршрута месяца — SPA, встречи, практики, события.' });

  // deduplicate by name, limit to 3
  const seen = new Set();
  return recs.filter(r => { if(seen.has(r.name)) return false; seen.add(r.name); return true; }).slice(0,3);
}

/* ─── STATE ─── */
const LS = 'bcdt_k4_v1';
function load() { try { const d=localStorage.getItem(LS); return d?JSON.parse(d):null; } catch { return null; } }
function save(s) { try { localStorage.setItem(LS,JSON.stringify(s)); } catch {} }
function clear() { try { localStorage.removeItem(LS); } catch {} }
function fresh() { return { answers:{}, completed:[], scores:{}, date:null, todayCount:0 }; }

let ST = load() || fresh();

function today() { const d=new Date(); return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }
function resetDay() { if(ST.date!==today()) { ST.todayCount=0; ST.date=today(); save(ST); } }

