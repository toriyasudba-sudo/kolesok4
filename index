        ${cardsHtml}
      </div>
      <div style="display:flex;gap:12px;margin-top:28px;flex-wrap:wrap">
        <button class="btn btn-ghost" id="restartBtn" style="flex:1;justify-content:center">Пройти заново</button>
        <button class="btn btn-ghost" id="hubBtn3" style="flex:1;justify-content:center">Все сферы</button>
      </div>
    </div>
  </div>

  <footer class="footer">
    <div style="color:var(--gold)">${LOGO}</div>
    <p>К4 — Клан читательниц БЧДТ. Пространство, где журнал становится живым маршрутом.</p>
    <small>© Клан БЧДТ</small>
  </footer>
</div>`;

  document.getElementById('dlBtn').onclick=()=>dlWheel(scores,avg,cardRecs);
  document.getElementById('emlBtn').onclick=()=>showModal(scores,avg,verdict,cardRecs);
  document.getElementById('restartBtn').onclick=()=>{ clear(); ST=fresh(); go(renderIntro); };
  document.getElementById('hubBtn3').onclick=()=>go(renderHub);
}

/* ─── WHEEL SVG ─── */
function buildWheel(scores) {
  const R=130, RINGS=[32,65,98,130];
  const angs=scores.map((_,i)=>(-90+i*45)*Math.PI/180);
  const pts=scores.map((s,i)=>{ const r=(s.score/10)*R; return {x:(Math.cos(angs[i])*r).toFixed(1),y:(Math.sin(angs[i])*r).toFixed(1),score:s.score}; });
  const poly=pts.map(p=>`${p.x},${p.y}`).join(' ');
  const rings=RINGS.map(r=>`<circle cx="0" cy="0" r="${r}" class="${r===130?'wrm':'wr'}"/>`).join('');
  const axes=angs.map((a,i)=>`<line x1="0" y1="0" x2="${(Math.cos(a)*R).toFixed(1)}" y2="${(Math.sin(a)*R).toFixed(1)}" class="wa" style="animation-delay:${i*.05}s"/>`).join('');
  const spokes=pts.map((p,i)=>`<line x1="0" y1="0" x2="${p.x}" y2="${p.y}" class="wsp" style="animation-delay:${.2+i*.06}s"/><circle cx="${p.x}" cy="${p.y}" r="3.5" class="wdt" style="animation-delay:${1+i*.05}s"/>`).join('');
  const labels=scores.map((s,i)=>{
    const lr=R+22, x=(Math.cos(angs[i])*lr).toFixed(1), y=(Math.sin(angs[i])*lr).toFixed(1);
    const anc=Math.cos(angs[i])<-.1?'end':Math.cos(angs[i])>.1?'start':'middle';
    const sc=s.score<4?'low':s.score>=7?'hi':'';
    const dl=(1.4+i*.07).toFixed(2);
    return `<text class="wlb" x="${x}" y="${(+y-6).toFixed(1)}" text-anchor="${anc}" style="animation-delay:${dl}s">${s.name}</text>
    <text class="wsc ${sc}" x="${x}" y="${(+y+10).toFixed(1)}" text-anchor="${anc}" font-size="16" style="animation-delay:${dl}s">${s.score.toFixed(1)}</text>`;
  }).join('');
  return `<svg id="wheelSvg" viewBox="-180 -180 360 360" xmlns="http://www.w3.org/2000/svg" style="overflow:visible">${rings}${axes}<polygon points="${poly}" class="wpo"/>${spokes}${labels}</svg>`;
}

/* ─── VERDICT ─── */
function genVerdict(scores,avg) {
  const b=Object.fromEntries(scores.map(s=>[s.id,s]));
  const sorted=[...scores].sort((a,b)=>a.score-b.score);
  const lo=sorted[0],lo2=sorted[1],hi=sorted[sorted.length-1];
  let main;
  if(avg>=8) main='Твоя жизнь сейчас устойчива. Ты слышишь себя и движешься в своём ритме.';
  else if(avg>=6.5) main='Держишься хорошо — но внутри уже давно нет настоящего выдоха.';
  else if(avg>=5) main='Снаружи всё нормально. Внутри — усталость, которую ты научилась не замечать.';
  else if(avg>=3.5) main='Ты тащишь много — и делаешь это в одиночку, давно не останавливаясь.';
  else main='Твоя жизнь сейчас требует внимания. Настоящего — не «потом».';
  const points=[];
  if(lo.score<4) points.push(`«${lo.name}» — самая уязвимая точка прямо сейчас.`);
  if(lo2.score<4&&lo2.id!==lo.id) points.push(`«${lo2.name}» тоже требует внимания.`);
  const h=b.health,m=b.money,c=b.career,r=b.rel,st=b.state,s=b.self,e=b.env,rs=b.rest;
  if(h&&c&&h.score<5&&c.score>=7) points.push('Реализация работает — но тело финансирует этот темп.');
  if(m&&st&&m.score>=7&&st.score<4) points.push('Финансовая стабильность есть — а её носитель истощён.');
  if(r&&st&&r.score>=7&&st.score<4) points.push('Близкие рядом — а внутри пусто.');
  if(e&&e.score<4) points.push('Среда сейчас забирает больше, чем отдаёт.');
  if(s&&s.score<3) points.push('Тебя нет в твоём собственном списке — это заметно по всему.');
  if(hi.score-lo.score>=6) points.push(`Разрыв в ${(hi.score-lo.score).toFixed(0)} балла между «${hi.name}» и «${lo.name}» — это не баланс, это перевес.`);
  if(scores.every(s=>s.score>=5&&s.score<=7)) points.push('Вся жизнь выровнена в середине. Это не гармония — это плато.');
  if(!points.length) points.push(`«${hi.name}» — твоя точка опоры прямо сейчас. Опирайся.`);
  return {main,points};
}

/* ─── DOWNLOAD ─── */
function dlWheel(scores,avg,cardRecs) {
  const W=1080,H=1600,canvas=document.createElement('canvas');
  canvas.width=W; canvas.height=H;
  const ctx=canvas.getContext('2d');

  // bg
  ctx.fillStyle='#F5EFE4'; ctx.fillRect(0,0,W,H);

  // top line
  ctx.strokeStyle='rgba(184,144,46,.4)'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(60,90); ctx.lineTo(W-60,90); ctx.stroke();

  // logo area
  ctx.textAlign='center'; ctx.fillStyle='#2B3828';
  ctx.font='300 13px "Jost", sans-serif'; ctx.letterSpacing='4px';
  ctx.fillText('КЛАН ЧИТАТЕЛЬНИЦ БЧДТ', W/2, 68);

  // big K4
  ctx.font='300 52px "Cormorant Garamond", Georgia, serif';
  ctx.fillStyle='#2B3828'; ctx.letterSpacing='0';
  ctx.fillText('К', W/2-14, 68);
  ctx.fillStyle='#B8902E';
  ctx.font='300 28px "Cormorant Garamond", Georgia, serif';
  ctx.fillText('4', W/2+12, 60);

  // title
  ctx.fillStyle='rgba(43,56,40,.85)';
  ctx.font='300 44px "Cormorant Garamond", Georgia, serif'; ctx.letterSpacing='-1px';
  ctx.fillText('Твоё колесо баланса', W/2, 148);

  // date
  const dStr=new Date().toLocaleDateString('ru-RU',{day:'numeric',month:'long',year:'numeric'});
  ctx.fillStyle='rgba(184,144,46,.7)'; ctx.font='200 12px "Jost", sans-serif'; ctx.letterSpacing='3px';
  ctx.fillText(dStr.toUpperCase(), W/2, 178);

  ctx.strokeStyle='rgba(184,144,46,.2)'; ctx.lineWidth=.6;
  ctx.beginPath(); ctx.moveTo(100,196); ctx.lineTo(W-100,196); ctx.stroke();

  // wheel
  const CX=W/2,CY=560,R=268;
  const angs=scores.map((_,i)=>(-90+i*45)*Math.PI/180);
  const pts=scores.map((s,i)=>({x:CX+Math.cos(angs[i])*(s.score/10)*R,y:CY+Math.sin(angs[i])*(s.score/10)*R,score:s.score}));

  [.25,.5,.75,1].forEach(f=>{
    ctx.beginPath(); ctx.arc(CX,CY,R*f,0,Math.PI*2);
    ctx.strokeStyle=f===1?'rgba(184,144,46,.25)':'rgba(43,56,40,.06)';
    ctx.lineWidth=f===1?.8:.5;
    ctx.setLineDash(f===1?[3,4]:[]);
    ctx.stroke(); ctx.setLineDash([]);
  });
  angs.forEach(a=>{ ctx.beginPath(); ctx.moveTo(CX,CY); ctx.lineTo(CX+Math.cos(a)*R,CY+Math.sin(a)*R); ctx.strokeStyle='rgba(43,56,40,.07)'; ctx.lineWidth=.5; ctx.stroke(); });

  ctx.beginPath(); pts.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y)); ctx.closePath();
  ctx.fillStyle='rgba(184,144,46,.13)'; ctx.fill();
  ctx.beginPath(); pts.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y)); ctx.closePath();
  ctx.strokeStyle='#B8902E'; ctx.lineWidth=1.5; ctx.lineJoin='round'; ctx.stroke();

  pts.forEach(p=>{ ctx.beginPath(); ctx.moveTo(CX,CY); ctx.lineTo(p.x,p.y); ctx.strokeStyle='#B8902E'; ctx.lineWidth=1.2; ctx.lineCap='round'; ctx.stroke(); ctx.beginPath(); ctx.arc(p.x,p.y,4,0,Math.PI*2); ctx.fillStyle='#B8902E'; ctx.fill(); });

  scores.forEach((s,i)=>{
    const lr=R+44,x=CX+Math.cos(angs[i])*lr,y=CY+Math.sin(angs[i])*lr;
    const anc=Math.cos(angs[i])<-.15?'right':Math.cos(angs[i])>.15?'left':'center';
    ctx.textAlign=anc; ctx.fillStyle='rgba(43,56,40,.35)'; ctx.font='200 10px "Jost", sans-serif'; ctx.letterSpacing='2px';
    ctx.fillText(s.name.toUpperCase(),x,y-8);
    ctx.fillStyle=s.score<4?'#8B6055':s.score>=7?'#9A7620':'rgba(43,56,40,.6)';
    ctx.font='italic 300 26px "Cormorant Garamond", Georgia, serif'; ctx.letterSpacing='0px';
    ctx.fillText(s.score.toFixed(1),x,y+16);
  });

  ctx.textAlign='center'; ctx.fillStyle='#B8902E';
  ctx.font='300 68px "Cormorant Garamond", Georgia, serif'; ctx.fillText(avg.toFixed(1),W/2,CY);
  ctx.fillStyle='rgba(184,144,46,.4)'; ctx.font='200 10px "Jost", sans-serif'; ctx.letterSpacing='3px';
  ctx.fillText('СРЕДНИЙ БАЛЛ',W/2,CY+22);

  // score list
  const lY=CY+R+72, colW=(W-120)/2;
  ctx.textAlign='left';
  scores.forEach((s,i)=>{
    const col=i%2,row=Math.floor(i/2),x=60+col*(colW+40),y=lY+row*58;
    ctx.strokeStyle='rgba(43,56,40,.07)'; ctx.lineWidth=.5;
    ctx.beginPath(); ctx.moveTo(x,y+26); ctx.lineTo(x+colW,y+26); ctx.stroke();
    ctx.fillStyle='rgba(184,144,46,.55)'; ctx.font='italic 300 14px "Cormorant Garamond", Georgia, serif';
    ctx.fillText(s.roman,x,y+18);
    ctx.fillStyle='rgba(43,56,40,.7)'; ctx.font='300 14px "Cormorant Garamond", Georgia, serif';
    ctx.fillText(s.name,x+20,y+18);
    ctx.fillStyle=s.score<4?'#8B6055':s.score>=7?'#9A7620':'rgba(43,56,40,.5)';
    ctx.font='italic 300 22px "Cormorant Garamond", Georgia, serif'; ctx.textAlign='right';
    ctx.fillText(s.score.toFixed(1),x+colW,y+18); ctx.textAlign='left';
  });

  // cards recs
  const cY=lY+4*58+40;
  ctx.strokeStyle='rgba(184,144,46,.3)'; ctx.lineWidth=.6;
  ctx.beginPath(); ctx.moveTo(60,cY); ctx.lineTo(W-60,cY); ctx.stroke();
  ctx.textAlign='center'; ctx.fillStyle='rgba(184,144,46,.8)'; ctx.font='200 10px "Jost", sans-serif'; ctx.letterSpacing='3px';
  ctx.fillText('КАРТЫ К4 ДЛЯ ТЕБЯ',W/2,cY+28);
  ctx.textAlign='left';
  cardRecs.forEach((c,i)=>{
    const cy2=cY+52+i*72;
    ctx.fillStyle='#B8902E'; ctx.beginPath(); ctx.arc(60,cy2-3,4,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#2B3828'; ctx.font='300 18px "Cormorant Garamond", Georgia, serif'; ctx.letterSpacing='0';
    ctx.fillText(c.name,76,cy2);
    ctx.fillStyle='rgba(43,56,40,.5)'; ctx.font='italic 300 13px "Cormorant Garamond", Georgia, serif';
    const words=c.why.split(' '), line1=[], line2=[];
    let w=0;
    for(const wd of words) { if(w+wd.length<60){line1.push(wd);w+=wd.length+1}else{line2.push(wd);} }
    ctx.fillText(line1.join(' '),76,cy2+18);
    if(line2.length) ctx.fillText(line2.join(' '),76,cy2+34);
  });

  // bottom
  ctx.strokeStyle='rgba(184,144,46,.2)'; ctx.lineWidth=.6;
  ctx.beginPath(); ctx.moveTo(60,H-70); ctx.lineTo(W-60,H-70); ctx.stroke();
  ctx.textAlign='center'; ctx.fillStyle='rgba(43,56,40,.4)'; ctx.font='200 10px "Jost", sans-serif'; ctx.letterSpacing='4px';
  ctx.fillText('К4 · КЛАН ЧИТАТЕЛЬНИЦ БЧДТ',W/2,H-42);
  ctx.fillStyle='rgba(184,144,46,.3)'; ctx.font='200 9px "Jost", sans-serif'; ctx.letterSpacing='2px';
  ctx.fillText('ЖУРНАЛ «БОЛЬШЕ, ЧЕМ ДЕТОКС ТЕЛА»',W/2,H-24);

  const a=document.createElement('a');
  a.download='колесо-баланса-к4-бчдт.jpg';
  a.href=canvas.toDataURL('image/jpeg',.93); a.click();
}

/* ─── EMAIL MODAL ─── */
function showModal(scores,avg,verdict,cardRecs) {
  const isOk=CFG.emailjs_key&&CFG.emailjs_service&&CFG.emailjs_tpl;
  const resText=scores.map(s=>`${s.roman}. ${s.name}: ${s.score.toFixed(1)}/10`).join('\n')
    +`\n\nСредний балл: ${avg.toFixed(1)}/10\n\n${verdict.main}`;
  const cardsText='\n\nРЕКОМЕНДОВАНЫЕ КАРТЫ К4:\n'+cardRecs.map(c=>`• ${c.name} — ${c.why}`).join('\n');

  const ov=document.createElement('div');
  ov.className='moverlay'; ov.id='ov';
  ov.innerHTML=`<div class="modal">
    <button class="modal__x" id="mclose">✕</button>
    <h2 class="d modal__h">Получить на <em>почту</em></h2>
    <p class="modal__sub">Результат и рекомендации карт К4 придут тебе. Мы тоже увидим твоё колесо.</p>
    <div class="modal__form" id="mform">
      <input class="modal__inp" type="email" id="memail" placeholder="твой email">
      <input class="modal__inp" type="text" id="mname" placeholder="твоё имя (необязательно)">
      <button class="btn btn-primary" id="msend" style="width:100%;justify-content:center">${isOk?'Отправить':'Скопировать результат'}</button>
    </div>
  </div>`;
  document.body.appendChild(ov);
  ov.addEventListener('click',e=>{ if(e.target===ov) ov.remove(); });
  document.getElementById('mclose').onclick=()=>ov.remove();

  document.getElementById('msend').onclick=async()=>{
    const email=document.getElementById('memail').value.trim();
    const name=document.getElementById('mname').value.trim()||'участница';
    if(!isOk){ try{await navigator.clipboard.writeText(resText+cardsText);}catch{} showOk('Результат скопирован в буфер обмена.'); return; }
    if(!email||!email.includes('@')){ document.getElementById('memail').style.borderColor='#8B6055'; return; }
    const btn=document.getElementById('msend'); btn.textContent='Отправляем...'; btn.disabled=true;
    try {
      emailjs.init({publicKey:CFG.emailjs_key});
      await emailjs.send(CFG.emailjs_service,CFG.emailjs_tpl,{
        to_email:email, owner_email:CFG.owner_email, user_name:name,
        avg_score:avg.toFixed(1), date:new Date().toLocaleDateString('ru-RU'),
        results:resText, verdict:verdict.main, cards:cardsText
      });
      showOk(`Отправлено на ${email}`);
    } catch(err){
      btn.textContent='Ошибка — попробуй снова'; btn.disabled=false; console.error(err);
    }
  };

  function showOk(msg) {
    const f=document.getElementById('mform');
    if(f) f.innerHTML=`<div class="modal__ok"><span class="modal__ok-ic">✦</span><p class="modal__ok-t">${msg}</p></div><button class="btn btn-ghost" onclick="document.getElementById('ov').remove()" style="width:100%;justify-content:center;margin-top:16px">Закрыть</button>`;
  }
}

